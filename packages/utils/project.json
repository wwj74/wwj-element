{
  "name": "@wwj/utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/utils/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "pnpm clean",
            "forwardAllArgs": false
          },
          {
            "command": "pnpm build",
            "forwardAllArgs": false
          }
        ],
        "cwd": "packages/utils"
      },
      "outputs": [
        "{projectRoot}/dist"
      ],
      "dependsOn": [
        "^build"
      ]
    }
  },
  "tags": []
}
